<Window x:Class="MikiStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:MikiStore"
        Title="Miki Store" Height="500" Width="850"
        Background="#1E1E1E" Icon="/DO-NOT-REMOVE.ico">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:LengthConverter x:Key="LengthConverter" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="8" 
                        BorderThickness="0">
                            <ContentPresenter x:Name="Content" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#555555"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedUninstallStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="BorderBrush" Value="#FF4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                      Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding ButtonText}" Value="Launch">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <ScrollViewer x:Name="MainRoot" VerticalScrollBarVisibility="Auto" Margin="20">
            <StackPanel>

                <Label Content="Miki Store Catalog" FontSize="28" Foreground="White" Margin="0,0,0,20"/>



                <Border Background="#252525" CornerRadius="10" Margin="0,0,0,20" Padding="10,5">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="5,0,10,0" Foreground="Gray"/>

                        <TextBox x:Name="SearchBox" 

                     Grid.Column="1"

                     Background="Transparent" 

                     Foreground="White" 

                     BorderThickness="0" 

                     FontSize="16" 

                     VerticalAlignment="Center"

                     TextChanged="SearchBox_TextChanged"/>

                        <TextBlock IsHitTestVisible="False" 

                       Text="Search apps..." 

                       VerticalAlignment="Center" 

                       Grid.Column="1" 

                       Margin="5,0,0,0" 

                       Foreground="DimGray">

                            <TextBlock.Style>

                                <Style TargetType="TextBlock">

                                    <Setter Property="Visibility" Value="Collapsed"/>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">

                                            <Setter Property="Visibility" Value="Visible"/>

                                        </DataTrigger>

                                    </Style.Triggers>

                                </Style>

                            </TextBlock.Style>

                        </TextBlock>

                    </Grid>

                </Border>



                <ListBox x:Name="AppList" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Border Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="0,5" Cursor="Hand" MouseLeftButtonUp="AppCard_Click">

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="Auto"/>

                                        <ColumnDefinition Width="*"/>

                                        <ColumnDefinition Width="Auto"/>

                                    </Grid.ColumnDefinitions>



                                    <Border Grid.Column="0" 

Width="50" 

Height="50" 

HorizontalAlignment="Left"

VerticalAlignment="Center"

Margin="0,0,15,0" 

CornerRadius="8" 

ClipToBounds="True" 

Background="#1A1A1A">

                                        <Grid>

                                            <ui:ProgressRing 

    Width="45" 

    Height="45"

    Foreground="White"

    IsActive="{Binding isIconInstalling}" 

    Visibility="{Binding isIconInstalling, Converter={StaticResource BoolToVis}}"

    HorizontalAlignment="Center" 

    VerticalAlignment="Center">

                                                <ui:ProgressRing.RenderTransform>

                                                    <RotateTransform Angle="0" CenterX="22.5" CenterY="22.5"/>

                                                </ui:ProgressRing.RenderTransform>

                                            </ui:ProgressRing>



                                            <Image gif:ImageBehavior.AnimatedSource="{Binding IconUrl}"

       Loaded="Icon_Loaded_Trigger" 

       Width="50" 

       Height="50" 

       Stretch="UniformToFill"

       RenderOptions.BitmapScalingMode="HighQuality">

                                            </Image>

                                        </Grid>

                                    </Border>



                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">

                                        <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="White"/>

                                        <TextBlock Text="{Binding Description, Converter={StaticResource LengthConverter}}" 

   Foreground="Gray" 

   TextWrapping="Wrap" 

   Margin="0,2,20,0" 

   MaxHeight="40"/>

                                        <ProgressBar Height="4" Margin="0,8,20,0" Foreground="#007ACC" Background="#1A1A1A"

                                             Value="{Binding DownloadProgress}"

                                             IsIndeterminate="{Binding IsIntermediate}"

                                             Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    </StackPanel>



                                    <Button Grid.Column="2" 
                                            Style="{StaticResource RoundedButtonStyle}"
                                            Content="{Binding ButtonText}" 
                                            Background="{Binding ButtonColor}" 
                                            Click="Install_Click" 
                                            Foreground="White" 
                                            Padding="20,8" 
                                            VerticalAlignment="Center" 
                                            BorderThickness="0" Cursor="Hand"/>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>

        </ScrollViewer>

        <Grid x:Name="DetailsPanel" Background="#CC000000" Visibility="Collapsed">
            <Border Background="#252525" CornerRadius="15" Margin="50" MaxWidth="700" VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <StackPanel Margin="30">
                        <Button Content="← Back to Catalog" HorizontalAlignment="Left" Background="Transparent" Foreground="SkyBlue" BorderThickness="0" Cursor="Hand" Click="Back_Click" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="12" ClipToBounds="True" Background="#1A1A1A" Width="80" Height="80" VerticalAlignment="Top" Margin="0,0,20,0">
                                <Grid>
                                    <ui:ProgressRing 
    Width="74" 
    Height="74"
    Foreground="White"
    IsActive="{Binding isIconInstalling}" 
    Visibility="{Binding isIconInstalling, Converter={StaticResource BooleanToVisibilityConverter}}"
    HorizontalAlignment="Center" 
    VerticalAlignment="Center">
                                        <ui:ProgressRing.RenderTransform>
                                            <!-- Rotate it by 90, 180, or 270 degrees -->
                                            <RotateTransform Angle="360" CenterX="37" CenterY="37"/>
                                        </ui:ProgressRing.RenderTransform>
                                    </ui:ProgressRing>
                                    <Image gif:ImageBehavior.AnimatedSource="{Binding IconUrl}"
Stretch="UniformToFill" 
RenderOptions.BitmapScalingMode="HighQuality">
                                    </Image>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="32" FontWeight="ExtraBold" Foreground="White" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Version}" FontSize="14" Foreground="Gray"/>
                                <TextBlock Text="{Binding UploadedBy}" FontSize="14" Foreground="Gray"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#1A1A1A" Padding="20" CornerRadius="10">
                            <TextBlock Text="{Binding Description}" Foreground="LightGray" FontSize="16" TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel Margin="0,20,0,0">

                            <ProgressBar Value="{Binding DownloadProgress}" 
                 Height="10" 
                 Foreground="#28A745" 
                 Background="#1A1A1A" 
                 BorderThickness="0" 
                                         IsIndeterminate="{Binding IsIntermediate}"
                 Margin="0,0,0,10">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="DetailActionBtn"
                                        Style="{StaticResource RoundedButtonStyle}"
Content="{Binding ButtonText}" 
Background="{Binding ButtonColor}" 
Padding="30,10" 
Foreground="White" 
BorderThickness="0" 
Click="Install_Click" 
Cursor="Hand"/>

                                <Button x:Name="DetailUninstallBtn" 
                                        Style="{StaticResource RoundedUninstallStyle}"
Content="Uninstall" 
Padding="20,10" Margin="15,0,0,0" 
Background="Transparent" Foreground="#FF4444" 
BorderBrush="#FF4444" BorderThickness="1" 
Click="Uninstall_Click" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <Label x:Name="VersionLabel"
                Content="" HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="0,0,0,0" 
                Foreground="LightGray" 
                RenderTransformOrigin="1,1"/>

    </Grid>
</Window>